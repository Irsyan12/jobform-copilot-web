---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import DemoVideo from '../components/DemoVideo.astro';
import Features from '../components/Features.astro';
import PrivacyPolicy from '../components/PrivacyPolicy.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>

<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>JobForm Copilot - AI-Powered Recruitment Assistant</title>
    <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      body {
        background: radial-gradient(
          circle at top center,
          #111827 0%,
          #030712 100%
        );
        min-height: 100vh;
      }
      .glow-shadow {
        box-shadow: 0 0 30px rgba(79, 70, 229, 0.2);
      }
      .glow-hover:hover {
        box-shadow: 0 0 40px rgba(79, 70, 229, 0.3);
      }
      .border-beam {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(
          45deg,
          transparent 40%,
          rgba(79, 70, 229, 0.5) 50%,
          transparent 60%
        );
        background-size: 200% 200%;
        animation: beam 3s linear infinite;
        -webkit-mask:
          linear-gradient(#fff 0 0) content-box,
          linear-gradient(#fff 0 0);
        mask:
          linear-gradient(#fff 0 0) content-box,
          linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
      }
      @keyframes beam {
        0% {
          background-position: 100% 100%;
        }
        100% {
          background-position: 0% 0%;
        }
      }
    </style>
    <script is:inline id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "surface-container-lowest": "#080e1a",
              "secondary-fixed": "#dce2f7",
              "on-secondary-fixed-variant": "#404758",
              outline: "#918fa1",
              "on-tertiary-fixed-variant": "#2f2ebe",
              "surface-container-low": "#161c28",
              "primary-container": "#4f46e5",
              "surface-bright": "#343946",
              "tertiary-fixed-dim": "#c0c1ff",
              warning: "#F59E0B",
              surface: "#111827",
              tertiary: "#c0c1ff",
              "inverse-on-surface": "#2b303d",
              secondary: "#c0c6db",
              "surface-container": "#1a202c",
              "on-primary": "#1d00a5",
              "secondary-container": "#404758",
              "on-error": "#690005",
              muted: "#374151",
              "tertiary-container": "#4b4dd8",
              "outline-variant": "#464555",
              "on-primary-fixed": "#0f0069",
              "inverse-primary": "#4d44e3",
              "on-surface": "#F3F4F6",
              "on-surface-variant": "#c7c4d8",
              "on-secondary-container": "#aeb5c9",
              "surface-container-high": "#242a36",
              "surface-dim": "#0e131f",
              "on-tertiary-container": "#d9d8ff",
              "error-container": "#93000a",
              "on-error-container": "#ffdad6",
              success: "#10B981",
              "secondary-fixed-dim": "#c0c6db",
              "surface-tint": "#c3c0ff",
              "on-primary-container": "#dad7ff",
              "surface-container-highest": "#2f3542",
              "on-secondary": "#293040",
              "on-tertiary": "#1000a9",
              "border-glass": "rgba(255, 255, 255, 0.1)",
              primary: "#c3c0ff",
              subtle: "#1F2937",
              "inverse-surface": "#dde2f3",
              background: "#0e131f",
              "primary-fixed-dim": "#c3c0ff",
              "on-background": "#dde2f3",
              "on-primary-fixed-variant": "#3323cc",
              "primary-fixed": "#e2dfff",
              "tertiary-fixed": "#e1e0ff",
              error: "#EF4444",
              "on-secondary-fixed": "#141b2b",
              "on-tertiary-fixed": "#07006c",
              "surface-variant": "#2f3542",
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
            spacing: {
              xl: "8.875rem",
              section: "4.5rem",
              xs: "0.5rem",
              lg: "3rem",
              md: "2.25rem",
              "container-max": "1280px",
              gutter: "1.5rem",
              sm: "1.25rem",
            },
            fontFamily: {
              "headline-lg": ["Inter"],
              "label-lg": ["Inter"],
              "body-lg": ["Inter"],
              "headline-sm": ["Inter"],
              "body-md": ["Inter"],
              "body-sm": ["Inter"],
              "label-sm": ["Inter"],
              overline: ["Inter"],
              "headline-display": ["Inter"],
              "headline-display-mobile": ["Inter"],
              "headline-md": ["Inter"],
              "label-md": ["Inter"],
            },
            fontSize: {
              "headline-lg": [
                "39px",
                {
                  lineHeight: "47px",
                  letterSpacing: "-0.01em",
                  fontWeight: "700",
                },
              ],
              "label-lg": [
                "16px",
                {
                  lineHeight: "24px",
                  letterSpacing: "0.01em",
                  fontWeight: "600",
                },
              ],
              "body-lg": [
                "20px",
                { lineHeight: "30px", letterSpacing: "0px", fontWeight: "400" },
              ],
              "headline-sm": [
                "25px",
                { lineHeight: "32px", letterSpacing: "0px", fontWeight: "600" },
              ],
              "body-md": [
                "16px",
                { lineHeight: "24px", letterSpacing: "0px", fontWeight: "400" },
              ],
              "body-sm": [
                "14px",
                { lineHeight: "20px", letterSpacing: "0px", fontWeight: "400" },
              ],
              "label-sm": [
                "12px",
                {
                  lineHeight: "16px",
                  letterSpacing: "0.02em",
                  fontWeight: "600",
                },
              ],
              overline: [
                "12px",
                {
                  lineHeight: "16px",
                  letterSpacing: "0.1em",
                  fontWeight: "700",
                },
              ],
              "headline-display": [
                "48px",
                {
                  lineHeight: "48px",
                  letterSpacing: "-0.02em",
                  fontWeight: "900",
                },
              ],
              "headline-display-mobile": [
                "36px",
                {
                  lineHeight: "40px",
                  letterSpacing: "-0.02em",
                  fontWeight: "900",
                },
              ],
              "headline-md": [
                "31px",
                {
                  lineHeight: "40px",
                  letterSpacing: "-0.01em",
                  fontWeight: "600",
                },
              ],
              "label-md": [
                "14px",
                {
                  lineHeight: "20px",
                  letterSpacing: "0.01em",
                  fontWeight: "600",
                },
              ],
            },
          },
        },
      };
    </script>
  </head>
  <body
    class="text-on-surface font-body-md bg-background overflow-x-hidden selection:bg-primary-container selection:text-white"
  >
    <Navbar />
    <main class="w-full flex flex-col items-center">
      <Hero />
      <DemoVideo />
      <HowItWorks />
      <Features />
      <PrivacyPolicy />
    </main>
    <Footer />
  </body>
</html>
