---
---
<section class="w-full bg-surface-container-low/50 py-section border-y border-border-glass">
  <div class="max-w-container-max mx-auto px-gutter">
    <div class="text-center mb-16">
      <h2 class="font-headline-lg text-headline-lg text-on-surface mb-4">Why JobForm Copilot?</h2>
      <p class="font-body-md text-body-md text-on-surface-variant max-w-xl mx-auto">
        Built for modern recruiters who demand power, precision, and privacy.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Feature 1 -->
      <div class="p-6 rounded-xl bg-surface/60 backdrop-blur-md border border-border-glass flex gap-4">
        <div class="w-12 h-12 rounded-lg bg-surface-container flex items-center justify-center shrink-0 border border-white/5">
          <span class="material-symbols-outlined text-primary">description</span>
        </div>
        <div>
          <h4 class="font-label-lg text-label-lg text-on-surface mb-2">PDF to AI Profile</h4>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Convert static PDF documents into dynamic, queryable candidate profiles in seconds.</p>
        </div>
      </div>
      <!-- Feature 2 -->
      <div class="p-6 rounded-xl bg-surface/60 backdrop-blur-md border border-border-glass flex gap-4">
        <div class="w-12 h-12 rounded-lg bg-surface-container flex items-center justify-center shrink-0 border border-white/5">
          <span class="material-symbols-outlined text-primary">vpn_key</span>
        </div>
        <div>
          <h4 class="font-label-lg text-label-lg text-on-surface mb-2">Bring Your Own Key (BYOK)</h4>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Use your own OpenAI or Anthropic API keys. Pay only for what you use, directly to the provider.</p>
        </div>
      </div>
      <!-- Feature 3 -->
      <div class="p-6 rounded-xl bg-surface/60 backdrop-blur-md border border-border-glass flex gap-4">
        <div class="w-12 h-12 rounded-lg bg-surface-container flex items-center justify-center shrink-0 border border-white/5">
          <span class="material-symbols-outlined text-primary">shield_lock</span>
        </div>
        <div>
          <h4 class="font-label-lg text-label-lg text-on-surface mb-2">100% Local &amp; Private</h4>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Your data never leaves your browser except to hit your configured AI provider. We store nothing.</p>
        </div>
      </div>
      <!-- Feature 4 -->
      <div class="p-6 rounded-xl bg-surface/60 backdrop-blur-md border border-border-glass flex gap-4">
        <div class="w-12 h-12 rounded-lg bg-surface-container flex items-center justify-center shrink-0 border border-white/5">
          <span class="material-symbols-outlined text-primary">psychology</span>
        </div>
        <div>
          <h4 class="font-label-lg text-label-lg text-on-surface mb-2">Smart Context</h4>
          <p class="font-body-sm text-body-sm text-on-surface-variant">The AI understands the context of the forms you are filling, ensuring accurate data placement.</p>
        </div>
      </div>
    </div>
  </div>
</section>
