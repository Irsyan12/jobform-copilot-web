---
const currentYear = new Date().getFullYear();
---
<footer class="w-full bg-surface-container-low border-t border-border-glass py-12 mt-20">
  <div class="max-w-container-max mx-auto px-gutter flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex items-center gap-3">
      <img alt="JobForm Copilot Logo" class="w-8 h-8 opacity-80" src="/assets/jobform-icon1.png" />
      <span class="font-headline-sm text-headline-sm font-bold text-on-surface">JobForm Copilot</span>
    </div>
    
    <div class="flex gap-6 font-body-sm text-body-sm">
      <a class="text-on-surface-variant hover:text-primary transition-colors font-medium" href="#how-it-works">How It Works</a>
      <a class="text-on-surface-variant hover:text-primary transition-colors font-medium" href="#privacy-policy">Privacy Policy</a>
      <a class="text-on-surface-variant hover:text-primary transition-colors font-medium" href="mailto:support@jobformcopilot.com">Contact Support</a>
    </div>
    
    <div class="font-body-sm text-body-sm text-on-surface-variant/70">
      &copy; {currentYear} JobForm Copilot. All rights reserved.
    </div>
  </div>
</footer>
