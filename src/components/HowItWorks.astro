---
---
<section class="w-full max-w-container-max mx-auto px-gutter py-section" id="how-it-works">
  <div class="text-center mb-16">
    <h2 class="font-headline-lg text-headline-lg text-on-surface mb-4">How It Works</h2>
    <p class="font-body-md text-body-md text-on-surface-variant max-w-xl mx-auto">
      A seamless workflow designed to integrate AI directly into your recruitment process without compromising privacy.
    </p>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Step 1 -->
    <div class="relative p-8 rounded-2xl bg-surface/50 backdrop-blur-xl border border-border-glass hover:bg-surface-container hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(79,70,229,0.3)] hover:border-primary/40 transition-all duration-300 group">
      <div class="absolute -top-5 -left-5 w-14 h-14 bg-surface-container-highest rounded-2xl flex items-center justify-center font-headline-sm text-headline-sm text-on-surface shadow-xl border border-border-glass group-hover:bg-primary-container group-hover:text-white group-hover:border-primary-container transition-colors duration-300 transform -rotate-3 group-hover:rotate-0">1</div>
      <span class="material-symbols-outlined text-4xl text-primary mb-6 block transition-transform duration-300">upload_file</span>
      <h3 class="font-headline-sm text-headline-sm text-on-surface mb-3">Upload Resumes</h3>
      <p class="font-body-md text-body-md text-on-surface-variant">Drop PDF resumes directly into your browser. Our extension reads and processes them instantly.</p>
    </div>
    <!-- Step 2 -->
    <div class="relative p-8 rounded-2xl bg-surface/50 backdrop-blur-xl border border-border-glass hover:bg-surface-container hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(79,70,229,0.3)] hover:border-primary/40 transition-all duration-300 group">
      <div class="absolute -top-5 -left-5 w-14 h-14 bg-surface-container-highest rounded-2xl flex items-center justify-center font-headline-sm text-headline-sm text-on-surface shadow-xl border border-border-glass group-hover:bg-primary-container group-hover:text-white group-hover:border-primary-container transition-colors duration-300 transform -rotate-3 group-hover:rotate-0">2</div>
      <span class="material-symbols-outlined text-4xl text-primary mb-6 block transition-transform duration-300">smart_toy</span>
      <h3 class="font-headline-sm text-headline-sm text-on-surface mb-3">AI Processing</h3>
      <p class="font-body-md text-body-md text-on-surface-variant">Connect your own API key. The AI locally analyzes the document to extract structured candidate data.</p>
    </div>
    <!-- Step 3 -->
    <div class="relative p-8 rounded-2xl bg-surface/50 backdrop-blur-xl border border-border-glass hover:bg-surface-container hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(79,70,229,0.3)] hover:border-primary/40 transition-all duration-300 group">
      <div class="absolute -top-5 -left-5 w-14 h-14 bg-surface-container-highest rounded-2xl flex items-center justify-center font-headline-sm text-headline-sm text-on-surface shadow-xl border border-border-glass group-hover:bg-primary-container group-hover:text-white group-hover:border-primary-container transition-colors duration-300 transform -rotate-3 group-hover:rotate-0">3</div>
      <span class="material-symbols-outlined text-4xl text-primary mb-6 block transition-transform duration-300">assignment_turned_in</span>
      <h3 class="font-headline-sm text-headline-sm text-on-surface mb-3">Auto-Fill Forms</h3>
      <p class="font-body-md text-body-md text-on-surface-variant">Seamlessly map the extracted AI data into your existing ATS or recruitment web forms with one click.</p>
    </div>
  </div>
</section>
