<section class="w-full max-w-container-max mx-auto px-gutter pb-section flex justify-center mt-8">
  <div class="relative w-full max-w-5xl aspect-video rounded-xl overflow-hidden border border-border-glass bg-surface-container shadow-[0_20px_50px_rgba(0,0,0,0.5)] z-20 group">
    <div class="border-beam"></div>
    <img alt="JobForm Copilot Demo" class="w-full h-full object-cover transform transition-transform duration-700" src="/assets/jobcopilot-video.webp" />

    <!-- Mac-style window controls overlay -->
    <div class="absolute top-0 left-0 w-full h-10 bg-surface-container-highest/90 backdrop-blur-md border-b border-border-glass flex items-center px-4 gap-2">
      <div class="w-3 h-3 rounded-full bg-error/80"></div>
      <div class="w-3 h-3 rounded-full bg-warning/80"></div>
      <div class="w-3 h-3 rounded-full bg-success/80"></div>
    </div>
  </div>
</section>
